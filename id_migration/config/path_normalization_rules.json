{
  "version": "1.0",
  "repository_root": "C:\\Users\\richg\\eafix-modular",
  "storage_contract": {
    "relative_to_repository_root": true,
    "separator": "/",
    "preserve_original_case": true,
    "windows_comparison": "case_insensitive",
    "posix_comparison": "case_sensitive",
    "encoding": "UTF-8"
  },
  "rules": [
    {
      "id": "root_stripping",
      "description": "All stored paths are relative to repository_root with no leading slash or backslash."
    },
    {
      "id": "separator_normalization",
      "description": "Convert all path separators to forward slash for storage and comparison."
    },
    {
      "id": "duplicate_separator_collapse",
      "description": "Collapse consecutive separators before persisting a path."
    },
    {
      "id": "trailing_separator_stripping",
      "description": "Strip trailing separators from directory paths."
    },
    {
      "id": "dot_segment_resolution",
      "description": "Resolve . and .. segments before storage."
    }
  ],
  "examples": [
    {
      "input": ".\\services\\flow-orchestrator\\src\\2099900149260118_coordinator.py",
      "normalized": "services/flow-orchestrator/src/2099900149260118_coordinator.py"
    },
    {
      "input": "EA-REG//module_catalog.json",
      "normalized": "EA-REG/module_catalog.json"
    }
  ]
}
