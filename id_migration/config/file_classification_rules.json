{
  "version": "1.0",
  "default_scope_class": "module_owned",
  "blank_module_id_allowed_for": [
    "test",
    "tooling",
    "legacy",
    "out_of_scope"
  ],
  "classifications": {
    "module_owned": {
      "is_semantic_candidate": true,
      "module_binding": "resolved_in_generator"
    },
    "shared": {
      "is_semantic_candidate": true,
      "future_module_symbol": "SHARED_LIBS"
    },
    "config_data": {
      "is_semantic_candidate": true,
      "future_module_symbol": "F1_CONFIG_PREFERENCES"
    },
    "test": {
      "is_semantic_candidate": false,
      "blank_module_id_allowed": true
    },
    "tooling": {
      "is_semantic_candidate": false,
      "blank_module_id_allowed": true
    },
    "legacy": {
      "is_semantic_candidate": false,
      "blank_module_id_allowed": true
    },
    "out_of_scope": {
      "is_semantic_candidate": false,
      "blank_module_id_allowed": true
    }
  },
  "rules": [
    {
      "match_type": "path_prefix",
      "values": [
        "tests/"
      ],
      "scope_class": "test"
    },
    {
      "match_type": "path_prefix",
      "values": [
        "scripts/",
        "ci/",
        "tools/",
        "compliance/"
      ],
      "scope_class": "tooling"
    },
    {
      "match_type": "path_prefix",
      "values": [
        "shared/"
      ],
      "scope_class": "shared"
    },
    {
      "match_type": "path_prefix",
      "values": [
        "config/",
        "schemas/"
      ],
      "scope_class": "config_data"
    },
    {
      "match_type": "path_contains",
      "values": [
        "Directory management system/"
      ],
      "scope_class": "legacy"
    },
    {
      "match_type": "path_contains",
      "values": [
        ".git/",
        "__pycache__/",
        "node_modules/",
        ".pytest_cache/",
        ".mypy_cache/",
        "htmlcov/",
        "out/",
        ".runs/",
        ".state/"
      ],
      "scope_class": "out_of_scope"
    }
  ]
}
