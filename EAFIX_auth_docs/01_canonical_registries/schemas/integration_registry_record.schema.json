{
  "$id": "integration.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "authority_status": {
      "enum": [
        "canonical",
        "canonical_candidate",
        "generated",
        "supporting_evidence",
        "implementation_evidence",
        "legacy_source",
        "needs_review"
      ]
    },
    "change_request_refs": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "consumer_module_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "contract_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "delivery_semantics": {
      "type": [
        "string",
        "null"
      ]
    },
    "direction": {
      "type": [
        "string",
        "null"
      ]
    },
    "effective_from_utc": {
      "type": [
        "string",
        "null"
      ]
    },
    "fallback_integration_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_pattern": {
      "type": [
        "string",
        "null"
      ]
    },
    "heartbeat": {},
    "host": {
      "type": [
        "string",
        "null"
      ]
    },
    "integration_id": {
      "type": "string"
    },
    "integration_record_type": {
      "enum": [
        "channel",
        "endpoint",
        "topic",
        "file_transport",
        "data_store",
        "external_system"
      ]
    },
    "integration_status": {
      "type": "string"
    },
    "last_verified_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "ordering_semantics": {
      "type": [
        "string",
        "null"
      ]
    },
    "owner_module_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "polling": {},
    "port": {
      "type": [
        "integer",
        "null"
      ]
    },
    "producer_module_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "protocol": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_id": {
      "minLength": 1,
      "type": "string"
    },
    "record_type": {
      "minLength": 1,
      "type": "string"
    },
    "record_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "route": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "source_hashes": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "source_refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "commit_sha": {
            "type": [
              "string",
              "null"
            ]
          },
          "line_end": {
            "minimum": 1,
            "type": [
              "integer",
              "null"
            ]
          },
          "line_start": {
            "minimum": 1,
            "type": [
              "integer",
              "null"
            ]
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "role": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "path",
          "role",
          "commit_sha"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "status": {
      "enum": [
        "candidate",
        "active",
        "canonical",
        "planned",
        "partial",
        "conflicted",
        "deprecated",
        "superseded",
        "retired",
        "archived"
      ]
    },
    "superseded_by": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "supersedes": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "topic": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "record_type",
    "record_id",
    "schema_version",
    "record_version",
    "status",
    "authority_status",
    "source_refs",
    "source_hashes",
    "confidence",
    "effective_from_utc",
    "supersedes",
    "superseded_by",
    "change_request_refs",
    "last_verified_commit",
    "integration_id",
    "name",
    "integration_record_type",
    "integration_status",
    "protocol",
    "direction",
    "owner_module_id",
    "producer_module_ids",
    "consumer_module_ids",
    "contract_ids",
    "host",
    "port",
    "route",
    "topic",
    "file_pattern",
    "polling",
    "heartbeat",
    "delivery_semantics",
    "ordering_semantics",
    "fallback_integration_id",
    "artifact_refs"
  ],
  "title": "Integration registry record",
  "type": "object"
}
