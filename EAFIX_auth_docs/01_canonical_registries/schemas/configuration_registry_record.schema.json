{
  "$id": "configuration.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_values": {
      "type": "array"
    },
    "authority_status": {
      "enum": [
        "canonical",
        "canonical_candidate",
        "generated",
        "supporting_evidence",
        "implementation_evidence",
        "legacy_source",
        "needs_review"
      ]
    },
    "change_request_refs": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "config_id": {
      "type": "string"
    },
    "config_type": {
      "type": "string"
    },
    "consumer_step_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "default": {},
    "effective_from_utc": {
      "type": [
        "string",
        "null"
      ]
    },
    "environment_override": {
      "type": [
        "string",
        "null"
      ]
    },
    "formula": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_known_good_policy": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_verified_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "maximum": {
      "type": [
        "number",
        "null"
      ]
    },
    "minimum": {
      "type": [
        "number",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "operator_mutable": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "owner_module_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_id": {
      "minLength": 1,
      "type": "string"
    },
    "record_type": {
      "minLength": 1,
      "type": "string"
    },
    "record_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "restart_required": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "safety_class": {
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "secret_classification": {
      "type": "string"
    },
    "source_hashes": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "source_kind": {
      "type": "string"
    },
    "source_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "commit_sha": {
            "type": [
              "string",
              "null"
            ]
          },
          "line_end": {
            "minimum": 1,
            "type": [
              "integer",
              "null"
            ]
          },
          "line_start": {
            "minimum": 1,
            "type": [
              "integer",
              "null"
            ]
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "role": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "path",
          "role",
          "commit_sha"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "status": {
      "enum": [
        "candidate",
        "active",
        "canonical",
        "planned",
        "partial",
        "conflicted",
        "deprecated",
        "superseded",
        "retired",
        "archived"
      ]
    },
    "superseded_by": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "supersedes": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "unit": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "record_type",
    "record_id",
    "schema_version",
    "record_version",
    "status",
    "authority_status",
    "source_refs",
    "source_hashes",
    "confidence",
    "effective_from_utc",
    "supersedes",
    "superseded_by",
    "change_request_refs",
    "last_verified_commit",
    "config_id",
    "name",
    "config_type",
    "default",
    "allowed_values",
    "minimum",
    "maximum",
    "unit",
    "formula",
    "owner_module_id",
    "consumer_step_ids",
    "source_kind",
    "source_path",
    "environment_override",
    "operator_mutable",
    "restart_required",
    "safety_class",
    "last_known_good_policy",
    "secret_classification"
  ],
  "title": "Configuration registry record",
  "type": "object"
}
